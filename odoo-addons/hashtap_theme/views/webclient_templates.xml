<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Browser tab title: "HashTap" -->
    <template id="hashtap_title" name="HashTap Title" inherit_id="web.layout">
        <xpath expr="//title" position="replace">
            <title>HashTap</title>
        </xpath>
    </template>

    <!-- Favicon: Odoo'nun view inheritance whitelist'i @rel / @href
         öznitelikleri kabul etmediği için xpath ile override edilemiyor.
         Şirket logosunu Ayarlar → Şirketler altında HashTap logosu olarak
         ayarlamak /web ve /web/login çevresinde HashTap mark'ını gösterir.
    -->

</odoo>
